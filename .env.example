# Webhook notification (Discord/Slack/n8n endpoint for instant alerts)
APPOINTMENT_WEBHOOK_URL=
WR_OPS_WEBHOOK_URL=
WR_ENABLE_EMAIL_OUTBOUND=
WR_ENABLE_TEXT_OUTBOUND=

# Demo testimonials (internal staff unveiling only — never "true" in production)
