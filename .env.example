# Twilio API credentials (required for voicemail SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Voicemail SMS notifications — comma-separated E.164 phone numbers
# e.g. +15099511874,+15098225460
TWILIO_VOICEMAIL_NOTIFY_PHONES=

# Vapi receptionist
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# Google Calendar scheduling
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Google Maps / routing
GOOGLE_MAPS_API_KEY=

# Review destination
WR_GOOGLE_REVIEW_URL=
NEXT_PUBLIC_WR_GOOGLE_REVIEW_URL=

# Email transport
RESEND_API_KEY=
WR_EMAIL_FROM=

# Stripe deposits and payment links
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
