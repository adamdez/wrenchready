# Supabase (appointment storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Webhook notification (Discord/Slack/n8n endpoint for instant alerts)
APPOINTMENT_WEBHOOK_URL=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads conversion tracking (AW-XXXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Conversion label for phone click events (from Google Ads conversion action)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# Twilio voice forwarding
TWILIO_FORWARD_TO_PHONE=
TWILIO_CALLER_ID_NUMBER=
TWILIO_FORWARD_TIMEOUT_SECONDS=20

# Twilio API credentials (required for voicemail SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Voicemail SMS notifications — comma-separated E.164 phone numbers
# e.g. +15099511874,+15098225460
TWILIO_VOICEMAIL_NOTIFY_PHONES=
